{
  "name": "Baitak Flutter Dev",
  "image": "ghcr.io/cirruslabs/flutter:stable",
  "workspaceFolder": "/workspaces/baitak",
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter",
        "dart.flutterSdkPaths": ["/opt/flutter"],
        "editor.formatOnSave": true
      }
    }
  },
  "remoteEnv": {
    "ANDROID_HOME": "/opt/android-sdk-linux",
    "ANDROID_SDK_ROOT": "/opt/android-sdk-linux",
    "PATH": "${containerEnv:PATH}:/opt/flutter/bin:/opt/android-sdk-linux/platform-tools"
  },
  "postCreateCommand": "cd /workspaces/baitak/baitak_app && flutter pub get && flutter doctor -v || true"
}
